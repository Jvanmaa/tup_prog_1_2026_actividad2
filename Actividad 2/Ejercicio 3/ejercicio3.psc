Algoritmo ejercicio3
	definir Nro como real;
	escribir "Ingrese número a evaluar";
	leer Nro
	si Nro < 0 Entonces
		escribir "Número negativo";
	SiNo
		si Nro = 0 Entonces
			escribir "Cero";
		sino
			si Nro > 0 Entonces
				escribir "Número positivo";
			FinSi
		FinSi
	FinSi
FinAlgoritmo
